# ── Server ──
PORT=3000
NODE_ENV=development

# ── AI Pipeline ──
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
RIME_API_KEY=
RIME_VOICE=cove

# ── Agent Identity ──
AGENT_NAME=Maria
COMPANY_NAME=Orlando Motors
DEFAULT_VOICE=cove
DEFAULT_PROMPT=default

# ── Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── API Auth ──
VOXVIDIA_API_SECRET=

# ── Supabase (optional — call logging + analytics) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── CRM (GoHighLevel — set USE_STUB_ADAPTERS=false to enable) ──
USE_STUB_ADAPTERS=true
CRM_BASE_URL=
CRM_API_KEY=

# ── Google Calendar (set USE_STUB_ADAPTERS=false to enable) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Outbound Webhooks (post-call analytics) ──
OUTBOUND_CRM_WEBHOOK_URL=
OUTBOUND_ANALYTICS_WEBHOOK_URL=
OUTBOUND_SLACK_WEBHOOK_URL=
