# ── Server ──
PORT=3000
NODE_ENV=development

# ── PersonaPlex ──
PERSONAPLEX_WS_URL=ws://localhost:8998/api/chat
DEFAULT_VOICE=NATF2.pt
DEFAULT_PROMPT=You enjoy having a good conversation.

# ── Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# ── Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── CRM (GoHighLevel) ──
CRM_BASE_URL=
CRM_API_KEY=

# ── Google Calendar ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Outbound Webhooks ──
OUTBOUND_CRM_WEBHOOK_URL=
OUTBOUND_ANALYTICS_WEBHOOK_URL=
OUTBOUND_SLACK_WEBHOOK_URL=
